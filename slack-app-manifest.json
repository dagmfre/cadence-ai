{
  "display_information": {
    "name": "Cadence",
    "description": "Engineering Delivery Manager AI — tracks sprint delivery risk and acts on GitHub + Slack.",
    "background_color": "#0b1220"
  },
  "features": {
    "bot_user": {
      "display_name": "Cadence",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "im:write",
        "users:read",
        "users:read.email",
        "channels:read",
        "groups:read",
        "channels:history",
        "groups:history",
        "im:history",
        "app_mentions:read",
        "reactions:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
