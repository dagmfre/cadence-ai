# Copy to .env and fill in. Never commit .env.
#
# Two audiences for these values:
#   • The web app takes its GitHub/Slack/board config from whatever each signed-in
#     account connects in the wizard — NOT from this file.
#   • This file configures the HEADLESS workspace: the CLI scripts (pnpm seed/scan/
#     pipeline:dry/reset:actions) and the daily cron trigger.
# Everything under "Required in production" is needed either way.

# ── Required in production ───────────────────────────────────────────────────
# Session store + all accounts. WITHOUT THIS the server silently falls back to an
# in-memory store and every restart wipes users, sessions and workspaces.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Makes session cookies Secure. Set this on the host.
NODE_ENV=production

# Port to listen on (Koyeb: match the service's exposed port, e.g. 8000).
PORT=8787

# Shared secret for the scheduled scan, since cron can't sign in. Use a long random
# string. Call it as:
#   POST /run-daily-scan  with header  Authorization: Bearer <CRON_SECRET>
#   (or ?key=<CRON_SECRET> if your scheduler only lets you set a URL)
CRON_SECRET=

# ── Gemini (agent pipeline + chat) ───────────────────────────────────────────
GEMINI_API_KEY=
# Code default is gemini-3.5-flash; set this to pin a different model.
GEMINI_MODEL=gemini-3.5-flash

# ── LangSmith (tracing) ──────────────────────────────────────────────────────
# Every scan run and every chat turn becomes one trace, with the LangGraph nodes,
# model calls and deterministic scan/execute steps nested underneath.
# Get a key at smith.langchain.com → Settings → API keys. Leave TRACING unset to disable.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cadence
# Only if your LangSmith account is outside the US region:
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# ── GitHub OAuth app (the wizard's primary "Sign in with GitHub") ────────────
# GitHub → Settings → Developer settings → OAuth Apps. Callback must be
# <your-url>/auth/github/callback. Without these only the PAT fallback works.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Headless workspace: GitHub (CLI + cron only) ─────────────────────────────
# Classic PAT with `repo` + `project` scopes (reads repo + Projects v2 board, writes labels/comments).
GITHUB_TOKEN_CLASSIC=
# Fine-grained fallback (Metadata R, Contents R+W, Issues R+W, Pull requests R+W, Workflows W, Checks R).
GITHUB_TOKEN=
# The repo the CLI/cron manage, "owner/name". Must have an OPEN MILESTONE — that is
# what Cadence treats as the sprint.
TARGET_REPO=owner/name
# Projects v2 board number (from the board URL /projects/N).
PROJECT_NUMBER=2
# Only this GitHub Actions check gates delivery risk (ignores unrelated fork workflows).
CI_CHECK_NAME=delivery-check

# ── Headless workspace: Slack (also powers the @Cadence listener) ────────────
# Bot User OAuth Token (starts xoxb-) — from OAuth & Permissions after install.
SLACK_BOT_TOKEN=
# App-Level Token (starts xapp-) with connections:write — Basic Information → App-Level Tokens.
SLACK_APP_TOKEN=
# Report channel ID (C…) — the bot must be invited to it.
SLACK_CHANNEL_ID=
# GitHub login → Slack MEMBER id (U…, not a D… DM channel), e.g. {"dagmfre":"U01ABC23"}.
# Invalid JSON here is ignored with a warning rather than crashing scans.
TEAM_MAP={}

# ── Autonomy dial for the headless workspace: observe | copilot | autopilot ──
AUTONOMY=copilot

# ── Seeder (demo data only) ──────────────────────────────────────────────────
# Public repo the seeder imports issue text from.
SOURCE_REPO=owner/name
OVERLOAD_REVIEWER=
LOAD_MODE=assignees
# Fresh items read as "stale" past this many minutes (demo shows staleness without real age).
STALE_THRESHOLD_MINUTES=30

# ── Debug ────────────────────────────────────────────────────────────────────
# Set to 1 to log the conversational agent's tool-call rounds.
CONVO_DEBUG=
